---
const steps = [
  {
    num: 1,
    title: 'Free Estimate',
    desc: 'Schedule and receive a thorough roof inspection from our Master Elite team at absolutely no cost to you.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    num: 2,
    title: 'Clear Plan',
    desc: 'A line-item breakdown of all repairs with no hidden surprise costs — you approve every detail before we start.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
  {
    num: 3,
    title: 'Professional Repair',
    desc: 'Master Elite technicians execute the repair with premium GAF-certified materials and back it with the best warranty in the industry.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="28" height="28"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  },
];
---

<section class="process-section" id="process" aria-labelledby="process-heading">
  <div class="container">
    <p class="section-tag reveal">HOW IT WORKS</p>
    <h2 class="section-title section-title--light reveal delay-100" id="process-heading">
      The Affordable Way in 3 Steps
    </h2>

    <div class="steps-row">
      {steps.map((step, i) => (
        <div class={`step-card reveal delay-${(i + 1) * 200}`}>
          <div class="step-card__num-wrap">
            <span class="step-card__num">{String(step.num).padStart(2, '0')}</span>
          </div>
          <div class="step-card__icon" set:html={step.icon} />
          <h3 class="step-card__title">{step.title}</h3>
          <p class="step-card__desc">{step.desc}</p>

          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true">
              <svg viewBox="0 0 40 16" fill="none" width="40"><path d="M0 8h36m0 0l-6-6m6 6l-6 6" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/></svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.process-section {
  background: var(--navy);
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}
/* Decorative background pattern */
.process-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 0%, rgba(232,96,14,0.12) 0%, transparent 50%),
    radial-gradient(circle at 80% 100%, rgba(232,96,14,0.08) 0%, transparent 50%);
  pointer-events: none;
}

.section-tag {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 700;
  font-size: 0.75rem;
  letter-spacing: 0.18em;
  color: var(--orange);
  text-transform: uppercase;
  margin-bottom: 12px;
}
.section-title {
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 60px;
}
.section-title--light {
  color: var(--text-inverse);
  font-style: italic;
}

.steps-row {
  display: flex;
  gap: 0;
  justify-content: center;
  align-items: flex-start;
  position: relative;
}

.step-card {
  flex: 1;
  max-width: 340px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 40px 32px;
  position: relative;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius-md);
  margin: 0 12px;
  transition: background var(--transition), transform var(--transition);
}
.step-card:hover {
  background: rgba(255,255,255,0.09);
  transform: translateY(-6px);
}

.step-card__num-wrap {
  position: absolute;
  top: -18px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--orange);
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.step-card__num {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 800;
  font-size: 0.75rem;
  color: white;
}

.step-card__icon {
  color: var(--orange);
  margin-top: 20px;
  margin-bottom: 20px;
  opacity: 0.9;
}

.step-card__title {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-inverse);
  margin-bottom: 12px;
}
.step-card__desc {
  font-size: 0.95rem;
  color: rgba(255,255,255,0.75);
  line-height: 1.65;
}

.step-connector {
  position: absolute;
  right: -32px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
}

@media (max-width: 900px) {
  .steps-row { flex-direction: column; align-items: center; }
  .step-card { margin: 12px 0; max-width: 480px; width: 100%; }
  .step-connector { display: none; }
}
</style>
