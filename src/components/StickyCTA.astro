<!-- Floating "Call Now" sticky button -->
<div class="sticky-cta" aria-label="Quick contact">
  <a href="tel:8135428462" class="sticky-cta__call" aria-label="Call (813) 542-8462">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C11.4 21 3 12.6 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
    <span class="sticky-cta__label">Call Now</span>
  </a>
  <a href="#contact" class="sticky-cta__estimate">Get Free Estimate</a>
</div>

<style>
.sticky-cta {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 900;
  display: flex;
  flex-direction: column;
  gap: 10px;
  align-items: flex-end;
}

.sticky-cta__call {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--orange);
  color: white;
  padding: 14px 20px;
  border-radius: 100px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
  box-shadow: 0 8px 32px rgba(232,96,14,0.45);
  transition: transform var(--transition), box-shadow var(--transition);
  animation: pulse-glow 2.5s infinite;
}
.sticky-cta__call:hover {
  transform: translateY(-3px) scale(1.04);
  box-shadow: 0 16px 40px rgba(232,96,14,0.5);
}

.sticky-cta__estimate {
  background: var(--navy);
  color: white;
  padding: 10px 18px;
  border-radius: 100px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 600;
  font-size: 0.82rem;
  box-shadow: 0 4px 20px rgba(26,61,110,0.35);
  transition: transform var(--transition), background var(--transition);
}
.sticky-cta__estimate:hover {
  transform: translateY(-2px);
  background: var(--navy-dark);
}

/* Hide on very small screens or within the hero / contact section */
@media (max-width: 480px) {
  .sticky-cta__estimate { display: none; }
  .sticky-cta { bottom: 16px; right: 16px; }
}
</style>
