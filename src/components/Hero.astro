---

<section class="hero" id="hero" aria-label="Hero">
  <!-- Background image with parallax overlay -->
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__overlay"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__badge reveal">
      <span class="badge-dot"></span>
      Tampa Bay's #1 Rated Roofing Contractor
    </div>

    <h1 class="hero__title reveal delay-100">
      Stop the Leak. Fast.<br/>
      <em>Professional Roof<br/>Repair.</em>
    </h1>

    <p class="hero__subtitle reveal delay-200">
      GAF Master Elite Certified &bullet; 30+ Years Tampa Bay Experience &bullet; A+ BBB Rated &bullet; FL Licensed &amp; Insured
    </p>

    <div class="hero__cta reveal delay-300">
      <a href="#contact" class="btn btn-primary btn-lg pulse">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Get a FREE Estimate
      </a>
      <a href="tel:8135428462" class="btn btn-secondary btn-lg">
        Call (813) 542-8462
      </a>
    </div>

    <!-- Floating stat cards -->
    <div class="hero__stats">
      <div class="stat-card reveal delay-300">
        <span class="stat-card__num">30+</span>
        <span class="stat-card__label">Years in Business</span>
      </div>
      <div class="stat-card reveal delay-400">
        <span class="stat-card__num">5,000+</span>
        <span class="stat-card__label">Roofs Completed</span>
      </div>
      <div class="stat-card reveal delay-500">
        <span class="stat-card__num">A+</span>
        <span class="stat-card__label">BBB Rating</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-indicator" aria-hidden="true">
    <div class="scroll-dot"></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  height: 100svh;
  min-height: 620px;
  max-height: 900px;
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* Background */
.hero__bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/hero-roof.jpg');
  background-size: cover;
  background-position: center 40%;
  transform: scale(1.05);
  transition: transform 8s ease;
  will-change: transform;
}
.hero:hover .hero__bg { transform: scale(1); }

.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    rgba(18, 44, 82, 0.88) 0%,
    rgba(26, 61, 110, 0.78) 45%,
    rgba(26, 61, 110, 0.40) 100%
  );
}

/* Content */
.hero__content {
  position: relative;
  z-index: 2;
  padding-top: 40px;
  padding-bottom: 80px;
  max-width: 860px;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 600;
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  padding: 6px 16px;
  border-radius: 100px;
  margin-bottom: 28px;
  text-transform: uppercase;
}
.badge-dot {
  width: 7px;
  height: 7px;
  background: var(--orange);
  border-radius: 50%;
  animation: pulse-glow 2s infinite;
}

.hero__title {
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.05;
  margin-bottom: 24px;
  text-shadow: 0 2px 24px rgba(0,0,0,0.3);
}
.hero__title em {
  font-style: italic;
  color: #fff;
}

.hero__subtitle {
  font-size: clamp(0.95rem, 1.5vw, 1.15rem);
  color: rgba(255,255,255,0.9);
  max-width: 640px;
  line-height: 1.7;
  margin-bottom: 40px;
}

/* CTA */
.hero__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 60px;
}
.btn-lg { padding: 18px 38px; font-size: 1.05rem; }
.pulse { animation: pulse-glow 2.5s infinite; }

/* Stat cards */
.hero__stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}
.stat-card {
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius-md);
  padding: 18px 30px;
  min-width: 130px;
  transition: background var(--transition), transform var(--transition);
}
.stat-card:hover { background: rgba(255,255,255,0.17); transform: translateY(-4px); }
.stat-card__num {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 800;
  font-size: 1.9rem;
  color: var(--orange);
  line-height: 1;
}
.stat-card__label {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.8);
  margin-top: 4px;
  font-family: 'Work Sans', sans-serif;
}

/* Scroll indicator */
.hero__scroll-indicator {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
}
.scroll-dot {
  width: 26px;
  height: 42px;
  border: 2px solid rgba(255,255,255,0.5);
  border-radius: 100px;
  position: relative;
}
.scroll-dot::after {
  content: '';
  position: absolute;
  top: 6px;
  left: 50%;
  transform: translateX(-50%);
  width: 5px;
  height: 5px;
  background: white;
  border-radius: 50%;
  animation: float 1.6s ease-in-out infinite;
}

@media (max-width: 768px) {
  .hero__stats { display: none; }
  .hero__cta { flex-direction: column; align-items: flex-start; }
  .btn-lg { width: 100%; justify-content: center; }
}
</style>
